# ---------------------------------------------------------------
# ローカル開発用設定サンプル (.env にコピーして編集してください)
# 実シークレット(API キー等)はここには書かず、.env に直接記入すること。
# .env は .gitignore に含まれており、リポジトリにコミットしません。
# ---------------------------------------------------------------

# Application
APP_NAME="Douga API"
ENVIRONMENT=development
DEBUG=true
# DEV_MODE=true でローカル開発時に Firebase 認証をスキップできます
DEV_MODE=true

# Database (Cloud SQL)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/douga

# Redis (Memorystore)
REDIS_URL=redis://localhost:6379/0

# Google Cloud Storage
# ローカル開発では USE_LOCAL_STORAGE=true にすることで GCS 不要で動作します
GCS_BUCKET_NAME=douga-assets
GCS_PROJECT_ID=your-gcp-project-id
USE_LOCAL_STORAGE=true

# Firebase
FIREBASE_PROJECT_ID=your-firebase-project-id

# CORS (省略時はデフォルト: localhost + 本番 Firebase Hosting を含む)
# ローカル開発でカスタムポートを使う場合のみ設定してください
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Edit session token — ローカル開発用のダミー値。本番では 32 文字以上のランダム値必須
EDIT_TOKEN_SECRET=change-me-in-production-use-at-least-32-chars

# AI API Keys (実際のキーは .env に直接記入してください)
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...
# ANTHROPIC_API_KEY=sk-ant-...

# File Upload
MAX_UPLOAD_SIZE_MB=500

# FFmpeg
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe

# Render settings
RENDER_OUTPUT_WIDTH=1920
RENDER_OUTPUT_HEIGHT=1080
RENDER_FPS=30
